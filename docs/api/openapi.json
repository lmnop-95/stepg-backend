              }
            ],
            "title": "Revenue Last Year"
          },
          "sido": {
            "minLength": 1,
            "title": "Sido",
            "type": "string"
          }
        },
        "required": [
          "biz_reg_no",
          "corporate_type",
          "sido",
          "fields_of_work_ids"
        ],
        "title": "OnboardingCompleteRequest",
        "type": "object"
