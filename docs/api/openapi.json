    "/onboarding/ocr": {
      "post": {
        "description": "\uc0ac\uc5c5\uc790\ub4f1\ub85d\uc99d OCR preview \u2014 DB \ubbf8\uc800\uc7a5.\n\nmultipart upload \u2192 chunked size-guarded read \u2192 `validate_upload`\n(size + MIME + magic-bytes + \ub2e8\uc77c \ud398\uc774\uc9c0 PDF) \u2192 `recognize_bizlicense` \u2192\n`OcrBizRegResponse`. multi-page PDF \ub294 BE \uc0ac\uc804 \uac80\uc99d\uc73c\ub85c 422 \uc989\uc2dc \uac70\ubd80\n(CLOVA \ud638\ucd9c \ube44\uc6a9 \uc808\uac10, Q31).",
        "operationId": "post_ocr_onboarding_ocr_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_post_ocr_onboarding_ocr_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OcrBizRegResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
