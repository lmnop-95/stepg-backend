# ===== App / Runtime =====
APP_ENV=development
LOG_LEVEL=INFO
FRONTEND_URL=
COOKIE_DOMAIN=
CORS_ORIGINS=[]

# ===== Auth =====
NEXTAUTH_SECRET=

# ===== Database (Postgres — dev runs in infra/docker-compose.dev.yml) =====
# infra/docker-compose.dev.yml은 POSTGRES_USER/PASSWORD/DB를 ${X:-stepg} 기본값으로 채웁니다.
# user/pw/db를 바꾸려면 compose 실행 셸에서 환경 변수로 export 하세요.
DATABASE_URL=postgresql+asyncpg://stepg:stepg@localhost:5432/stepg

# ===== Cache / Queue (Redis, ARQ broker) =====
REDIS_URL=redis://localhost:6379/0

# ===== Storage (M2 attachments — LocalFs in Phase 1) =====
# 미설정 시 default = `<repo-root>/storage` (`packages/core/.../config.py::_DEFAULT_STORAGE_ROOT`,
# editable workspace install 가정). 비-editable 설치 / staging / production 환경에서는
# 반드시 절대경로로 명시 (`~` expansion 허용; `is_absolute()` validator 통과 필수).
# 예: STORAGE_ROOT=/var/lib/stepg/storage
STORAGE_ROOT=

# ===== AI Providers =====
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CLOVA_OCR_URL=
CLOVA_OCR_SECRET=

# ===== External Data Sources =====
BIZINFO_API_KEY=
DATA_GO_KR_SERVICE_KEY=
KSTARTUP_API_KEY=

# ===== Email (Resend) =====
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ===== Observability =====
SENTRY_DSN_BACKEND=
SENTRY_DSN_WORKER=
LOGFIRE_TOKEN=
